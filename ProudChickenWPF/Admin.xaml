<Window x:Class="ProudChickenWPF.Admin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProudChickenWPF"
        mc:Ignorable="d"
        Title="Proud Chicken Admin Panel" Height="600" Width="900">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <DockPanel Grid.Row="0" Background="Beige" Margin="5" >
            <TextBlock Text="AdminPage" FontSize="16" VerticalAlignment="Center" Margin="10,0,0,0"  FontWeight="Bold"/>
            <Button x:Name="LogoutButton" Content="Logout" Height="30" Background="White" HorizontalAlignment="Right" Margin="0,0,10,0" Click="LogoutButton_Click" />
        </DockPanel>
        <TabControl Grid.Row="1">
            <TabItem Header="Kunde">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"></RowDefinition>
                        <RowDefinition Height="*"></RowDefinition>
                    </Grid.RowDefinitions>
                    <DockPanel Grid.Row="0" HorizontalAlignment="Left">
                        <TextBlock Text="PostNummer" VerticalAlignment="Center" />
                        <TextBox x:Name="TextBoxPostnummer" Width="100" Height="30" Margin="10,0,10,0"  VerticalContentAlignment="Center"/>
                        <Button x:Name="ShowKunderButton" Content="Vis Kunder" Height="30" Width="120" Background="Beige" Click="ShowKunderButton_Click" IsDefault="True"/>
                        <Button x:Name="AddNewKundeButton"  Content="TilFøje Ny kunde" Margin="15,0,0,0" Height="30" Width="150" Background="Beige" Click="AddNewKundeButton_Click"/>
                        <Button x:Name="OpdateKundeButton" Content="Opdater" Margin="20,0,0,0" Height="30" Width="90" Background="Beige" Click="OpdateKundeButton_Click"/>
                        <Button x:Name="SletKundeButton" Content="Slet" Margin="20,0,0,0" Height="30" Width="60" Background="Beige" Click="SletKundeButton_Click"/>
                    </DockPanel>

                    <DataGrid x:Name="KundeList" Grid.Row="1" Background="Beige"  Margin="0,20,0,0" SelectionMode="Single" IsReadOnly="True"/>
                    <Popup x:Name="popup" IsOpen="False" StaysOpen="false" Placement="Right" PopupAnimation="Slide" PlacementTarget="{Binding ElementName=AddNewKundeButton}" Width="350"  AllowsTransparency="True">
                        <StackPanel Background="GhostWhite">
                            <TextBlock Text="Tilføje/Opdate Kunde" Margin="20"  HorizontalAlignment="Center" FontSize="16" FontWeight="Bold"/>
                            <TextBlock x:Name="ErrorMessageTextBlock" Foreground="Red" FontWeight="Bold" Visibility="Collapsed" Margin="10,5,10,0"/>
                            <DockPanel  HorizontalAlignment="Left" Margin="10,0,0,0">
                                <TextBlock Text="*" VerticalAlignment="Center" Foreground="Red" />
                                <TextBlock Text="KundeNavn" Width="100" VerticalAlignment="Center" />
                                <TextBox x:Name="TextBoxKundeNavn" Width="100"  Height="30" Margin="10,0,10,0"  VerticalContentAlignment="Center"/>
                            </DockPanel>
                            <DockPanel  HorizontalAlignment="Left" Margin="10,10,0,0">
                                <TextBlock Text="*" VerticalAlignment="Center" Foreground="Red" />
                                <TextBlock Text="VejNavn"  Width="100" VerticalAlignment="Center" />
                                <TextBox x:Name="TextBoxVejNavn" Width="100" Height="30" Margin="10,0,10,0"  VerticalContentAlignment="Center"/>
                            </DockPanel>
                            <DockPanel  HorizontalAlignment="Left" Margin="10,10,0,0">
                                <TextBlock Text="*" VerticalAlignment="Center" Foreground="Red" />
                                <TextBlock Text="PostNummer"  Width="100" VerticalAlignment="Center" />
                                <TextBox x:Name="TextBoxPostNummer" Width="100" Height="30" Margin="10,0,10,0"  VerticalContentAlignment="Center"/>
                            </DockPanel>
                            <DockPanel  HorizontalAlignment="Left" Margin="10,10,0,0">
                                <TextBlock Text="*" VerticalAlignment="Center" Foreground="Red" />
                                <TextBlock Text="ByNavn"  Width="100" VerticalAlignment="Center" />
                                <TextBox x:Name="TextBoxByNavn" Width="100" Height="30" Margin="10,0,10,0"  VerticalContentAlignment="Center"/>
                            </DockPanel>
                            <DockPanel  HorizontalAlignment="Left" Margin="10,10,0,0">
                                <TextBlock Text="*" VerticalAlignment="Center" Foreground="Red" />
                                <TextBlock Text="TelefonNummer"  Width="100" VerticalAlignment="Center" />
                                <TextBox x:Name="TextBoxTelefonNummer" Width="100" Height="30" Margin="10,0,10,0"  VerticalContentAlignment="Center"/>
                            </DockPanel>
                            <DockPanel  HorizontalAlignment="Left" Margin="10,10,0,0">
                                <TextBlock Text="*" VerticalAlignment="Center" Foreground="Red" />
                                <TextBlock Text="Email"  Width="100" VerticalAlignment="Center" />
                                <TextBox x:Name="TextBoxEmail" Width="150" Height="30" Margin="10,0,10,0"  VerticalContentAlignment="Center"/>
                            </DockPanel>
                            <DockPanel  HorizontalAlignment="Left" Margin="10,10,0,0">
                                <TextBlock Text="*" VerticalAlignment="Center" Foreground="Red" />
                                <TextBlock Text="Vælg tilmeldingsmetode:" Width="150" Margin="0,10,0,5" />
                                <CheckBox x:Name="CheckBoxPreferEmail" IsChecked="True" Margin="10,0,0,0">Email</CheckBox>
                                <CheckBox x:Name="CheckBoxPreferSms" IsChecked="True" Margin="10,0,0,0">Sms</CheckBox>
                            </DockPanel>
                            <DockPanel  HorizontalAlignment="Left" Margin="10,10,0,0">
                                <TextBlock Text="Præferencer"  Width="100" VerticalAlignment="Center" />
                                <CheckBox x:Name="CheckBoxFrozen" IsChecked="True" Margin="10,0,0,0">Frozen</CheckBox>
                                <CheckBox x:Name="CheckBoxKold" IsChecked="True" Margin="10,0,0,0">Kold</CheckBox>
                                <CheckBox x:Name="CheckBoxVarm" IsChecked="True" Margin="10,0,0,0">Varm</CheckBox>
                            </DockPanel>

                            <Button x:Name="GemKundeButton" Content="Gem" Background="White" IsDefault="True" Height="30" Margin="20" Width="120" Click="GemKundeButton_Click"/>
                            
                            
                        </StackPanel>
                    </Popup>

                </Grid>

            </TabItem>
            <TabItem Header="Oprette Ny Besked">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Vertical" Margin="10">
                        <TextBlock x:Name="ErrorMessageBeskedTextBlock" Foreground="Red" FontWeight="Bold" Visibility="Collapsed" Margin="0,5,10,0"/>
                        <DockPanel Margin="0,20,0,0">
                            <TextBlock Text="Indhold" VerticalAlignment="Center" Width="70" />
                            <RichTextBox x:Name="TextBoxIndhold" SpellCheck.IsEnabled="True" Width="200" Height="80"  AcceptsReturn="True"  VerticalScrollBarVisibility="Auto"/>
                        </DockPanel>
                        <DockPanel Margin="0,20,0,0">
                            <CheckBox x:Name="CheckBoxSms">Send via Sms?</CheckBox>
                            <CheckBox x:Name="CheckBoxEmail" Margin="30,0,0,0">Send via Email?</CheckBox>
                        </DockPanel>
                        <DockPanel Margin="0,20,0,0">
                            <TextBlock Text="Dato" VerticalAlignment="Center" />
                            <DatePicker x:Name="DatePickerBesked" Margin="10,0,0,0" Width="100"></DatePicker>
                            <TextBlock Text="Tid" VerticalAlignment="Center" Margin="20,0,0,0"/>
                            <ComboBox Margin="20,0,0,0" x:Name="HoursComboBoxBesked" Width="50">
                                <ComboBoxItem Content="00" />
                                <ComboBoxItem Content="01" />
                                <ComboBoxItem Content="02" />
                                <ComboBoxItem Content="03" />
                                <ComboBoxItem Content="04" />
                                <ComboBoxItem Content="05" />
                                <ComboBoxItem Content="06" />
                                <ComboBoxItem Content="07" />
                                <ComboBoxItem Content="08" />
                                <ComboBoxItem Content="09" />
                                <ComboBoxItem Content="10" />
                                <ComboBoxItem Content="11" />
                                <ComboBoxItem Content="12" />
                                <ComboBoxItem Content="13" />
                                <ComboBoxItem Content="14" />
                                <ComboBoxItem Content="15" />
                                <ComboBoxItem Content="16" />
                                <ComboBoxItem Content="17" />
                                <ComboBoxItem Content="18" />
                                <ComboBoxItem Content="19" />
                                <ComboBoxItem Content="20" />
                                <ComboBoxItem Content="21" />
                                <ComboBoxItem Content="22" />
                                <ComboBoxItem Content="23" />
                            </ComboBox>
                            <TextBlock Text=":" FontWeight="Bold" VerticalAlignment="Center" Margin="5,0,5,0" />
                            <ComboBox x:Name="MinutesComboBoxBesked" Width="50" HorizontalAlignment="Left">
                                <ComboBoxItem Content="00" />
                                <ComboBoxItem Content="15" />
                                <ComboBoxItem Content="30" />
                                <ComboBoxItem Content="45" />
                            </ComboBox>
                        </DockPanel>
                        <Button x:Name="SendBeskedButton" Content="Send" IsDefault="True" Background="White" Height="30" Width="100" Margin="0,50,0,0" Click="SendBeskedButton_Click" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Vertical" Margin="10">
                        <DockPanel  Margin="20,20,0,0">
                            <TextBlock Text="PostNummer" VerticalAlignment="Center" Width="100"  />
                            <TextBox x:Name="TextPostNummerInBesked" HorizontalAlignment="Left" Width="100" Height="30" VerticalContentAlignment="Center"/>
                            <Button x:Name="KunderInBeskedButton" HorizontalAlignment="Center" Content=" Søg Kunder" VerticalAlignment="Center" Height="30" Width="150" Background="White" Margin="30,0,0,0" Click="KunderInBeskedButton_Click"/>
                        </DockPanel>

                        <ListBox x:Name="KundeGridBesked" Margin="20" SelectionMode="Multiple"  Height="400" Background="Beige" ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 ScrollViewer.HorizontalScrollBarVisibility="Auto" >
                            <ListBox.ItemTemplate>
                                <DataTemplate >
                                    <StackPanel Orientation="Vertical">
                                        <TextBlock FontWeight="Bold" Text="{Binding KundeNavn}"/>
                                        <TextBlock>
                                            <Run Text="{Binding VejNavn}"></Run>
                                            <Run Text=", "></Run>
                                            <Run Text="{Binding ByNavn}"></Run>
                                            <Run Text=", "></Run>
                                            <Run Text="{Binding PostNummer}"></Run>
                                        </TextBlock>
                                        <TextBlock>
                                            <Run Text="Email: "></Run>
                                            <Run Text="{Binding Email}"></Run>
                                            <Run Text=", "></Run>
                                            <Run Text="TelefonNummer: "></Run>
                                            <Run Text="{Binding TelefonNummer}"></Run>  
                                        </TextBlock>
                                        <TextBlock>
                                             <Run Text="PreferEmail: "></Run>
                                             <Run Text="{Binding PreferEmail}"></Run>
                                             <Run Text=", "></Run>
                                             <Run Text="PreferSms: "></Run>
                                             <Run Text="{Binding PreferSms}"></Run> 
                                        </TextBlock>
                                        <TextBlock>
                                            <Run Text="Varm: "></Run>
                                            <Run Text="{Binding Varm}"></Run>
                                            <Run Text=", "></Run>
                                            <Run Text="Frozen: "></Run>
                                            <Run Text="{Binding Frozen}"></Run>
                                            <Run Text=", "></Run>
                                            <Run Text="Kold: "></Run>
                                            <Run Text="{Binding Kold}"></Run>
                                        </TextBlock>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Grid>
            </TabItem>
            <TabItem Header="Besked Historik">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Vertical" Margin="10">
                        <DockPanel>
                            <TextBlock Text="Fra:" Width="80" VerticalAlignment="Center"/>
                            <DatePicker x:Name="StartDatePicker" Width="100" ></DatePicker>
                        </DockPanel>
                        <DockPanel Margin="0,10,0,0">
                            <TextBlock Text="Til" Width="80" VerticalAlignment="Center"/>
                            <DatePicker x:Name="EndDatePicker" Width="100" ></DatePicker>
                        </DockPanel>
                        <DockPanel Margin="0,10,0,0">
                            <TextBlock Text="Post Nummer:" Width="80" VerticalAlignment="Center"/>
                            <TextBox x:Name="PostNummerTextBox" Width="100" />
                        </DockPanel>
                        <DockPanel Margin="0,10,0,0">
                            <TextBlock Text="ByNavn:" VerticalAlignment="Center" Width="80"/>
                            <TextBox x:Name="ByNavnTextBox" Width="100" />
                        </DockPanel>
                        <DockPanel Margin="0,10,0,0">
                            <TextBlock Text="KundeNavn:" VerticalAlignment="Center" Width="80"/>
                            <TextBox x:Name="KundeNavnTextBox" Width="100" />
                        </DockPanel>
                        <Button Margin="0,20,0,0" x:Name="SøgBeskedButton" Width="100" Content="Søg" IsDefault="True" Background="White" Click="SøgBeskedButton_Click"/>

                    </StackPanel>
                    <DataGrid x:Name="ReportGrid" Margin="10" Grid.Column="1"  IsReadOnly="True" Background="Beige" AutoGenerateColumns="False" ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 ScrollViewer.HorizontalScrollBarVisibility="Auto" >
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="Indhold" Width="200" >
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Indhold}" TextWrapping="Wrap" FontWeight="Bold"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="BegivenhedsDato" Binding="{Binding BegivenhedsDato}" Width="175"/>
                            <DataGridTemplateColumn Header="Kunde Info" Width="260" >
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Vertical">
                                            <TextBlock Text="{Binding KundeNavn}" TextWrapping="Wrap" FontWeight="Bold"/>
                                            <TextBlock>
                                                  <Run Text="{Binding VejNavn}"/>,      
                                                  <Run Text="{Binding ByNavn}"/>
                                            </TextBlock>
                                            <TextBlock>
                                                 <Run Text="Sms Sendt:"/>
                                                 <Run Text="{Binding SendtSms}"/>,
                                                 <Run Text="Email Sendt:"/>
                                                 <Run Text="{Binding SendtEmail}"/>
                                            </TextBlock>
                                            <!--<TextBlock Text="{Binding SentDato}"/>-->
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
